<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="1050.0" spacing="15.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.CatalogController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <VBox>
                    <children>
                        <Label styleClass="header-title" text="JamuSync Catalog" />
                        <Label styleClass="header-subtitle" text="EXPLORE TRADITIONAL INDONESIAN HERBAL DRINKS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="searchField" prefWidth="220.0" promptText="Search products..." />
                <ComboBox fx:id="filterCombo" prefWidth="160.0" promptText="Filter by benefit..." />
                <Button mnemonicParsing="false" onAction="#handleBackToLogin" styleClass="button-outline" text="Back to Login" />
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <ScrollPane fitToWidth="true" prefWidth="620.0" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="productGrid" hgap="15.0" vgap="15.0" />
                    </content>
                </ScrollPane>

                <VBox prefWidth="380.0" spacing="12.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <Label styleClass="card-title" text="Product Details" />
                        <HBox alignment="CENTER" prefHeight="120.0" styleClass="image-preview-box">
                            <children>
                                <ImageView fx:id="detailImageView" fitHeight="110.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </HBox>
                        <Label fx:id="detailNameLabel" styleClass="detail-name" text="Select a product" wrapText="true" />
                        <Label fx:id="detailPriceLabel" styleClass="detail-price" />
                        <Label fx:id="detailDescriptionLabel" wrapText="true" />
                        <Label styleClass="label-form" text="Ingredients" />
                        <Label fx:id="detailIngredientsLabel" wrapText="true" />
                        <Label styleClass="label-form" text="Health Benefits" />
                        <Label fx:id="detailBenefitsLabel" wrapText="true" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Label styleClass="card-title" text="Jamu Assistant" />
                        <TextArea fx:id="chatHistoryArea" editable="false" prefHeight="120.0" promptText="Ask about jamu health benefits..." wrapText="true" />
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="chatInputField" promptText="Type your question..." HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleSendChat" styleClass="button-secondary" text="Ask" />
                            </children>
                        </HBox>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetRecommendations" text="Get Recommendations" />
                        <Label fx:id="recommendationLabel" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
