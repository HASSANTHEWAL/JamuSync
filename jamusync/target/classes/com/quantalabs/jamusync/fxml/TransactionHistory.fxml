<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700.0" prefWidth="1100.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.TransactionHistoryController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <children>
            <HBox alignment="CENTER_LEFT">
                <children>
                    <VBox>
                        <children>
                            <Label styleClass="header-title" text="Transaction History" />
                            <Label styleClass="header-subtitle" text="VIEW AND MANAGE ALL SALES TRANSACTIONS" />
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-outline" text="Back to Dashboard" />
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <children>
                    <VBox spacing="4.0">
                        <children>
                            <Label styleClass="label-form" text="Status" />
                            <ComboBox fx:id="statusFilter" prefWidth="140.0" />
                        </children>
                    </VBox>
                    <VBox spacing="4.0">
                        <children>
                            <Label styleClass="label-form" text="From Date" />
                            <DatePicker fx:id="startDatePicker" />
                        </children>
                    </VBox>
                    <VBox spacing="4.0">
                        <children>
                            <Label styleClass="label-form" text="To Date" />
                            <DatePicker fx:id="endDatePicker" />
                        </children>
                    </VBox>
                    <Button mnemonicParsing="false" onAction="#handleFilter" styleClass="button-secondary" text="Apply Filter">
                        <VBox.margin>
                            <Insets top="20.0" />
                        </VBox.margin>
                    </Button>
                    <Button mnemonicParsing="false" onAction="#handleClearFilter" styleClass="button-outline" text="Clear">
                        <VBox.margin>
                            <Insets top="20.0" />
                        </VBox.margin>
                    </Button>
                </children>
            </HBox>

            <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50.0" style="-fx-alignment: CENTER;" text="ID" />
                    <TableColumn fx:id="colBuyer" prefWidth="130.0" text="Buyer" />
                    <TableColumn fx:id="colType" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Type" />
                    <TableColumn fx:id="colSubtotal" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Subtotal" />
                    <TableColumn fx:id="colDiscount" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="Discount" />
                    <TableColumn fx:id="colTotal" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                    <TableColumn fx:id="colStatus" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Status" />
                    <TableColumn fx:id="colStaff" prefWidth="100.0" text="Recorded By" />
                    <TableColumn fx:id="colDate" prefWidth="130.0" text="Date" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox spacing="10.0">
                <children>
                    <Button mnemonicParsing="false" onAction="#handleViewDetails" text="View Details" />
                    <Button mnemonicParsing="false" onAction="#handleMarkCompleted" styleClass="button-secondary" text="Mark Completed" />
                    <Button mnemonicParsing="false" onAction="#handleMarkCancelled" styleClass="button-danger" text="Mark Cancelled" />
                </children>
            </HBox>
        </children>
    </VBox>
</HBox>
