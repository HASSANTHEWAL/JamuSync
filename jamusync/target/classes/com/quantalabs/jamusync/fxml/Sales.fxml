<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="700.0" prefWidth="1100.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.SalesController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <VBox prefWidth="650.0" spacing="15.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="25.0" left="25.0" right="15.0" top="25.0" />
        </padding>
        <children>
            <HBox alignment="CENTER_LEFT">
                <children>
                    <VBox>
                        <children>
                            <Label styleClass="header-title" text="Sales POS" />
                            <Label styleClass="header-subtitle" text="RECORD WALK-IN AND WHATSAPP ORDERS" />
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-outline" text="Back to Dashboard" />
                </children>
            </HBox>

            <HBox spacing="15.0">
                <children>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label styleClass="label-form" text="Order Type" />
                            <ComboBox fx:id="orderTypeCombo" maxWidth="1.7976931348623157E308" />
                        </children>
                    </VBox>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <children>
                            <Label styleClass="label-form" text="Buyer Name" />
                            <TextField fx:id="buyerNameField" promptText="Optional buyer name..." />
                        </children>
                    </VBox>
                </children>
            </HBox>

            <HBox spacing="10.0">
                <children>
                    <ComboBox fx:id="productCombo" prefWidth="250.0" promptText="Select product..." HBox.hgrow="ALWAYS" />
                    <TextField fx:id="quantityField" prefWidth="80.0" promptText="Qty" />
                    <Button mnemonicParsing="false" onAction="#handleAddToCart" styleClass="button-secondary" text="Add to Cart" />
                </children>
            </HBox>

            <TableView fx:id="cartTable" prefHeight="280.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProduct" prefWidth="220.0" text="Product" />
                    <TableColumn fx:id="colUnitPrice" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Unit Price" />
                    <TableColumn fx:id="colQty" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Qty" />
                    <TableColumn fx:id="colSubtotal" prefWidth="110.0" style="-fx-alignment: CENTER-RIGHT;" text="Subtotal" />
                    <TableColumn fx:id="colAction" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Action" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </VBox>

    <VBox prefWidth="400.0" spacing="15.0" styleClass="card" HBox.hgrow="NEVER">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <children>
            <Label styleClass="card-title" text="Order Summary" />
            <VBox spacing="4.0">
                <children>
                    <Label styleClass="label-form" text="Voucher Code" />
                    <HBox spacing="8.0">
                        <children>
                            <TextField fx:id="voucherCodeField" promptText="Enter voucher code..." HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#handleApplyVoucher" styleClass="button-outline" text="Apply" />
                        </children>
                    </HBox>
                    <Label fx:id="voucherInfoLabel" styleClass="label-muted" text="" wrapText="true" />
                </children>
            </VBox>
            <Label fx:id="subtotalLabel" styleClass="text-dark" text="Subtotal: Rp 0" />
            <Label fx:id="discountLabel" styleClass="text-accent" text="Discount: Rp 0" />
            <Label fx:id="totalLabel" styleClass="metric-value" text="Total: Rp 0">
                <style>
                    -fx-font-size: 20px;
                </style>
            </Label>
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="completeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCompleteSale" text="Complete Sale" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleClearCart" styleClass="button-outline" text="Clear Cart" />
            <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
        </children>
    </VBox>
</HBox>
