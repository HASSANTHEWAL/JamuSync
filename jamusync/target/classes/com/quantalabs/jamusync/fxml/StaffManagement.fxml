<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="root, screen-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.StaffManagementController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="20.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="30.0" right="20.0" top="30.0" />
        </padding>
        <children>
            <HBox alignment="CENTER_LEFT">
                <children>
                    <VBox>
                        <children>
                            <Label styleClass="header-title" text="Staff Management" />
                            <Label styleClass="header-subtitle" text="ADD, EDIT, OR DEACTIVATE STAFF ACCOUNTS" />
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-outline" text="Back to Dashboard" />
                </children>
            </HBox>
            <TableView fx:id="staffTable" minHeight="200.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50.0" style="-fx-alignment: CENTER;" text="ID" />
                    <TableColumn fx:id="colUsername" prefWidth="200.0" text="Username" />
                    <TableColumn fx:id="colActive" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Active" />
                    <TableColumn fx:id="colCreated" prefWidth="180.0" text="Created At" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </children>
    </VBox>

    <VBox prefWidth="450.0" styleClass="card" HBox.hgrow="NEVER">
        <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <children>
            <Label styleClass="card-title" text="Staff Account Form">
                <VBox.margin>
                    <Insets bottom="15.0" />
                </VBox.margin>
            </Label>
            <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                <children>
                    <VBox spacing="4.0">
                        <children>
                            <Label styleClass="label-form" text="Username *" />
                            <TextField fx:id="usernameField" promptText="Enter staff username..." />
                        </children>
                    </VBox>
                    <VBox spacing="4.0">
                        <children>
                            <Label styleClass="label-form" text="Password *" />
                            <PasswordField fx:id="passwordField" promptText="Enter password (required for new staff)..." />
                        </children>
                    </VBox>
                    <CheckBox fx:id="activeCheckbox" mnemonicParsing="false" selected="true" styleClass="label-form" text="Account is Active" />
                    <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
                </children>
            </VBox>
            <VBox spacing="8.0">
                <padding>
                    <Insets top="15.0" />
                </padding>
                <children>
                    <HBox spacing="10.0">
                        <children>
                            <Button fx:id="saveButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSave" text="Save Staff" HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#handleClear" styleClass="button-outline" text="Clear" />
                        </children>
                    </HBox>
                    <Button fx:id="deactivateButton" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeactivate" styleClass="button-danger" text="Deactivate Staff" />
                </children>
            </VBox>
        </children>
    </VBox>
</HBox>
