<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="root, screen-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.StaffDashboardController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    
    <!-- Sidebar Left -->
    <VBox maxHeight="1.7976931348623157E308" styleClass="sidebar" HBox.hgrow="NEVER">
        <children>
            <Label styleClass="sidebar-brand" text="JamuSync" />
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <children>
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-btn, sidebar-btn-active" text="Dashboard" />
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavSales" styleClass="sidebar-btn" text="Sales POS" />
                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavInventory" styleClass="sidebar-btn" text="Inventory" />
                </children>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-btn" text="Sign Out" />
        </children>
    </VBox>
    
    <!-- Main Right Content Area -->
    <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
        <children>
            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT" styleClass="top-bar">
                <children>
                    <VBox>
                        <children>
                            <Label styleClass="header-title" text="Dashboard" />
                            <Label styleClass="header-subtitle" text="STAFF OPERATION PANEL" />
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER_RIGHT">
                        <children>
                            <Label fx:id="profileLabel" styleClass="top-bar-username" text="Staff Name" />
                            <Label styleClass="top-bar-role" text="Staff" />
                        </children>
                    </VBox>
                </children>
            </HBox>
            
            <!-- Dashboard Content Container (Scrollable) -->
            <ScrollPane fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <content>
                    <VBox maxWidth="1.7976931348623157E308" spacing="25.0">
                        <padding>
                            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                        </padding>
                        <children>
                            <!-- Stats HBox -->
                            <HBox spacing="20.0">
                                <children>
                                    <!-- Metric Card 1 -->
                                    <VBox prefWidth="350.0" styleClass="card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="metric-label" text="Your Sales Revenue (Today)" />
                                            <Label fx:id="revenueLabel" styleClass="metric-value" text="Rp 0">
                                                <font>
                                                    <Font name="System Bold" size="24.0" />
                                                </font>
                                            </Label>
                                            <Label styleClass="metric-label" text="Completed orders recorded by you today">
                                                <font>
                                                    <Font name="System Italic" size="12.0" />
                                                </font>
                                            </Label>
                                        </children>
                                    </VBox>
                                    
                                    <!-- Metric Card 2 -->
                                    <VBox prefWidth="350.0" styleClass="card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="metric-label" text="Your Transactions Count (Today)" />
                                            <Label fx:id="salesCountLabel" styleClass="metric-positive" text="0 orders">
                                                <font>
                                                    <Font name="System Bold" size="24.0" />
                                                </font>
                                            </Label>
                                            <Label styleClass="metric-label" text="Transactions processed by you today">
                                                <font>
                                                    <Font name="System Italic" size="12.0" />
                                                </font>
                                            </Label>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                            
                            <!-- Recent Transactions Table Panel -->
                            <VBox spacing="10.0" styleClass="card" VBox.vgrow="ALWAYS">
                                <children>
                                    <Label styleClass="card-title" text="Your Recent Transactions" />
                                    <TableView fx:id="transactionsTable" minHeight="240.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="colTxId" prefWidth="60.0" style="-fx-alignment: CENTER;" text="ID" />
                                            <TableColumn fx:id="colTxBuyer" prefWidth="150.0" text="Buyer" />
                                            <TableColumn fx:id="colTxType" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Type" />
                                            <TableColumn fx:id="colTxTotal" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                                            <TableColumn fx:id="colTxStatus" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Status" />
                                            <TableColumn fx:id="colTxDate" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Recorded At" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </TableView>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </children>
    </VBox>
</HBox>
